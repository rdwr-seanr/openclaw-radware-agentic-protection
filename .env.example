# In-path: use the Radware in-path API key as the OpenClaw model-provider API key.
# Replace the base URL only with a Radware portal-confirmed proxy path, not a direct LLM provider URL.
RADWARE_INPATH_API_KEY=
RADWARE_INPATH_BASE_URL=https://api.agentic.radwarecto.com/v1/openai

# Out-of-path: use the Radware out-of-path API key for explicit Radware checks.
# New setup-generated configs check prompt, response, and tool stages.
RADWARE_OUT_OF_PATH_API_KEY=
RADWARE_OUT_OF_PATH_URL=https://api.agentic.radwarecto.com/llmp/digester/agentic-api

# The customer still needs their own LLM provider credentials for direct/non-in-path OpenClaw providers.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o

RADWARE_FAIL_MODE=fail-close
RADWARE_BEHAVIORAL_POLICY=block-and-report
RADWARE_INPATH_USER_IDENTIFIER=openclaw-in-path
RADWARE_USER_IDENTIFIER=openclaw-out-of-path
